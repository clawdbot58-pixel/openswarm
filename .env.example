# Copy to .env and fill in (or run: ./scripts/setup.sh)

# LLM — pick one profile in config/openswarm.toml ([llm] profile = ...)
# auto | nim | ollama | mock
OPENSWARM_LLM_PROFILE=auto

# NVIDIA NIM (24/7 production inference)
NVIDIA_API_KEY=
NIM_MODEL=meta/llama-3.1-8b-instruct
NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# Ollama (fast local testing)
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_MODEL=llama3.2

# Optional cloud fallbacks
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Telegram (OpenClaw-style chat channel)
TELEGRAM_BOT_TOKEN=
# Comma-separated chat IDs allowed to talk to the bot
OPENSWARM_TELEGRAM__ALLOWED_CHAT_IDS=

# Web search (Exa)
EXA_API_KEY=
